# Application Settings
APP_NAME="Recipe Builder API"
DEBUG=false

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# API
API_V1_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Supabase Storage (for recipe images)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=prepper
SUPABASE_RECIPE_IMAGES_FOLDER=recipe-images
SUPABASE_TASTING_NOTE_IMAGES_FOLDER=tasting-note-images
SUPABASE_INGREDIENT_TASTING_NOTE_IMAGES_FOLDER=ingredient-tasting-note-images

# Antropic API Key (for agents)
ANTHROPIC_API_KEY=your-antropic-api-key
